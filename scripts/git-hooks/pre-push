#!/usr/bin/env bash
# Pre-push hook — runs unit tests before a push leaves the machine.
# Installed via `make install-hooks`. CI is the binding gate; this is the early
# warning. Bypass in an emergency with `git push --no-verify`.
#
# Guarded: if there's no Gradle wrapper yet, it skips cleanly.
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

if [ ! -x ./gradlew ]; then
  echo "[pre-push] no ./gradlew yet — skipping."
  exit 0
fi

echo "[pre-push] unit tests…"
./gradlew testDebugUnitTest
